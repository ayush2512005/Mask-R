{
  "manifest_version": 3,
  "name": "Redact — Privacy Redaction Tool",
  "version": "0.1.0",
  "description": "Redact PII from files with one right-click. Powered by Redact.",
  "permissions": ["contextMenus", "tabs", "activeTab", "downloads"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/context-menu-handler.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*/*"],
      "js": ["src/content/pdf-viewer-button.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/download-interceptor.ts"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Redact"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
